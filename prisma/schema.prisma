generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  OPTICAL_STAFF
  PATIENT
}

enum BookingSource {
  ONLINE
  WALK_IN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RestockStatus {
  PENDING
  ORDERED
  RECEIVED
  CLOSED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ReminderMode {
  DISABLED
  PLANNED
}

enum ServiceOrderStatus {
  OPEN
  READY
  FULFILLED
}

model Branch {
  id            String   @id @default(cuid())
  name          String   @unique
  address       String
  contactNumber String
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  users         User[]
}

model SystemSetting {
  id                 String       @id
  defaultCurrency    String       @default("BDT")
  prescriptionFooter String
  reminderMode       ReminderMode @default(PLANNED)
  updatedAt          DateTime     @updatedAt
}

model User {
  id             String          @id @default(cuid())
  fullName       String
  email          String          @unique
  phone          String?
  passwordHash   String
  role           UserRole
  branchId       String?
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now())
  branch         Branch?         @relation(fields: [branchId], references: [id])
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
}

model DoctorProfile {
  id               String         @id @default(cuid())
  userId           String         @unique
  specialization   String
  qualification    String?
  experienceYears  Int?
  bio              String?
  consultationFee  Decimal?       @db.Decimal(10, 2)
  schedule         String?
  isActive         Boolean        @default(true)
  user             User           @relation(fields: [userId], references: [id])
  appointments     Appointment[]
  examinations     Examination[]
  prescriptions    Prescription[]
}

model PatientProfile {
  id            String          @id @default(cuid())
  userId        String?         @unique
  fullName      String
  phone         String
  email         String?
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  createdAt     DateTime        @default(now())
  user          User?           @relation(fields: [userId], references: [id])
  appointments  Appointment[]
  examinations  Examination[]
  prescriptions Prescription[]
  invoices      Invoice[]
  serviceOrders ServiceOrder[]
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  type        String
  duration    String
  priceLabel  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentDate String
  timeSlot        String
  status          AppointmentStatus @default(PENDING)
  serviceType     String
  bookingSource   BookingSource     @default(ONLINE)
  reason          String?
  createdAt       DateTime          @default(now())
  patient         PatientProfile    @relation(fields: [patientId], references: [id])
  doctor          DoctorProfile     @relation(fields: [doctorId], references: [id])
  examination     Examination?
  prescription    Prescription?

  @@unique([doctorId, appointmentDate, timeSlot])
}

model Examination {
  id              String         @id @default(cuid())
  appointmentId   String         @unique
  patientId       String
  doctorId        String
  leftEyeVision   String?
  rightEyeVision  String?
  diagnosis       String?
  notes           String?
  followUpAdvice  String?
  recommendations String?
  createdAt       DateTime       @default(now())
  appointment     Appointment    @relation(fields: [appointmentId], references: [id])
  patient         PatientProfile @relation(fields: [patientId], references: [id])
  doctor          DoctorProfile  @relation(fields: [doctorId], references: [id])
  prescription    Prescription?
}

model Prescription {
  id              String         @id @default(cuid())
  appointmentId   String         @unique
  patientId       String
  doctorId        String
  examinationId   String         @unique
  patientName     String
  doctorName      String
  leftEyeVision   String
  rightEyeVision  String
  diagnosis       String
  clinicalNotes   String
  lensPower       String
  medicines       String
  recommendations String
  advice          String
  printableText   String
  status          String         @default("FINALIZED")
  createdAt       DateTime       @default(now())
  patient         PatientProfile @relation(fields: [patientId], references: [id])
  doctor          DoctorProfile  @relation(fields: [doctorId], references: [id])
  appointment     Appointment    @relation(fields: [appointmentId], references: [id])
  examination     Examination    @relation(fields: [examinationId], references: [id])
}

model Product {
  id                String           @id @default(cuid())
  category          String
  name              String
  sku               String           @unique
  description       String
  price             Decimal          @db.Decimal(10, 2)
  stockQuantity     Int              @default(0)
  lowStockThreshold Int              @default(0)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  restockRequests   RestockRequest[]
}

model RestockRequest {
  id                String        @id @default(cuid())
  itemName          String
  productId         String?
  requiredQuantity  Int
  frequency         Int           @default(1)
  lastRequestedDate String
  status            RestockStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  product           Product?      @relation(fields: [productId], references: [id])
}

model ServiceOrder {
  id          String             @id @default(cuid())
  patientId   String?
  patientName String
  source      String
  items       Json
  totalAmount Decimal            @db.Decimal(10, 2)
  status      ServiceOrderStatus @default(OPEN)
  createdAt   DateTime           @default(now())
  patient     PatientProfile?    @relation(fields: [patientId], references: [id])
}

model Invoice {
  id            String          @id @default(cuid())
  referenceType String
  referenceId   String
  patientId     String?
  patientName   String
  totalAmount   Decimal         @db.Decimal(10, 2)
  paymentStatus PaymentStatus   @default(UNPAID)
  createdAt     DateTime        @default(now())
  patient       PatientProfile? @relation(fields: [patientId], references: [id])
}
